# Doc-genius 环境变量配置
# 复制为 .env 并填入实际值

# LLM 配置（可选，不配置则 LLM 功能不可用）
# LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen-plus

# LLM 提供商：dashscope / openai / deepseek / anthropic（默认 dashscope）
# dashscope/openai/deepseek 使用 OpenAI 兼容格式
# anthropic 使用 Claude 原生 Messages API
LLM_PROVIDER=dashscope

# 自定义 API 地址（可选，留空则使用对应提供商的默认地址）
# 各提供商默认地址：
#   dashscope:  https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
#   openai:     https://api.openai.com/v1/chat/completions
#   deepseek:   https://api.deepseek.com/v1/chat/completions
#   anthropic:  https://api.anthropic.com/v1/messages
# LLM_API_URL=

# ── 各提供商配置示例 ──
#
# 通义千问（默认）:
#   LLM_PROVIDER=dashscope
#   LLM_API_KEY=sk-xxx
#   LLM_MODEL=qwen-plus
#
# Claude:
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-xxx
#   LLM_MODEL=claude-sonnet-4-20250514
#
# DeepSeek:
#   LLM_PROVIDER=deepseek
#   LLM_API_KEY=sk-xxx
#   LLM_MODEL=deepseek-chat

# 服务配置
SKILLS_PORT=8766
SKILLS_HOST=0.0.0.0

# 并发
TASK_WORKERS=3

# 数据目录
SKILLS_DATA_DIR=~/.agent_skills

# CORS（生产环境请改为具体域名，多个用逗号分隔）
CORS_ORIGINS=*

# 调试
DEBUG=false
