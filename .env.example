# Doc-genius 环境变量配置
# 使用方法：cp .env.example .env 然后修改

# LLM 配置（可选，不配置则 LLM 功能不可用）
# 通义千问（推荐）：
LLM_API_KEY=sk-your-dashscope-key-here
LLM_MODEL=qwen-plus
LLM_PROVIDER=dashscope

# Claude（需要代理）：
# LLM_API_KEY=sk-xxx
# LLM_MODEL=claude-sonnet-4-6
# LLM_PROVIDER=anthropic
# LLM_API_URL=https://cc.580ai.net/v1/messages

# DeepSeek：
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat
# LLM_PROVIDER=deepseek

# 服务配置
SKILLS_PORT=8766
SKILLS_HOST=0.0.0.0
TASK_WORKERS=3
SKILLS_DATA_DIR=~/.agent_skills
CORS_ORIGINS=*
DEBUG=false

# 认证（生产环境设为 true）
AUTH_REQUIRED=false
JWT_SECRET=change-this-in-production
JWT_EXPIRE_HOURS=72
ADMIN_USERS=admin
