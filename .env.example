# Doc-genius 环境变量配置
# 复制为 .env 并填入实际值

# LLM 配置（必填）
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=qwen-plus

# LLM 提供商：dashscope / openai / deepseek（默认 dashscope）
# 三者均使用 OpenAI 兼容格式，切换时只需修改 provider、key 和 model
LLM_PROVIDER=dashscope

# 自定义 API 地址（可选，留空则使用对应提供商的默认地址）
# 各提供商默认地址：
#   dashscope: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
#   openai:    https://api.openai.com/v1/chat/completions
#   deepseek:  https://api.deepseek.com/v1/chat/completions
# LLM_API_URL=

# 服务配置
SKILLS_PORT=8766
SKILLS_HOST=0.0.0.0

# 并发
TASK_WORKERS=3

# 数据目录
SKILLS_DATA_DIR=~/.agent_skills

# CORS（生产环境请改为具体域名，多个用逗号分隔）
CORS_ORIGINS=*

# 调试
DEBUG=false
